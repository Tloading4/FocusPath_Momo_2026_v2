{
  "manifest_version": 3,
  "name": "Focus Path - Master Your Focus",
  "version": "1.0.0",
  "description": "Gamified productivity extension with focus tracking, XP system, and distraction management.",
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "idle",
    "notifications",
    "alarms",
    "contextMenus"
  ],
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://focuspathai.netlify.app/*", "http://localhost:*/*"],
      "js": ["webapp-bridge.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Focus Path",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["dashboard.html", "assets/*"],
      "matches": ["<all_urls>"]
    }
  ]
}