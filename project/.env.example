# Firebase Configuration
# Get these from Firebase Console: https://console.firebase.google.com
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Stripe Configuration
# Frontend (Client-side) - Get from: https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# Stripe Price IDs - Create in Stripe Dashboard: https://dashboard.stripe.com/products
VITE_STRIPE_PRICE_ID_MONTHLY=price_xxxxx_monthly
VITE_STRIPE_PRICE_ID_ANNUAL=price_xxxxx_annual

# Backend API URL (Python FastAPI service)
VITE_BACKEND_URL=http://localhost:8000

# Anthropic API Key — for local dev only (bypasses Firebase Function)
# Get from: https://console.anthropic.com/settings/api-keys
VITE_ANTHROPIC_API_KEY=your_anthropic_api_key
